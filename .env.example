FLASK_ENV=development
SECRET_KEY=revyo-clave-secreta-cambiame

# Base de datos (SQLite para desarrollo, PostgreSQL para producción)
DATABASE_URL=sqlite:///dev.db

# MercadoPago
MP_ACCESS_TOKEN=test
MP_PUBLIC_KEY=test
MP_WEBHOOK_SECRET=test

# URL de tu app
APP_URL=http://localhost:5000

# Precios de planes (en pesos CLP)
PLAN_BASIC_PRICE=9900
PLAN_PRO_PRICE=19900
PLAN_CURRENCY=CLP

# ─── EMAIL (Gmail) ────────────────────────────────────
# Para activar emails de confirmación:
# 1. Usa una cuenta Gmail
# 2. Activa verificación en 2 pasos en tu cuenta Google
# 3. Ve a: myaccount.google.com/apppasswords
# 4. Crea una "App password" para "Mail"
# 5. Pega esa contraseña de 16 caracteres en MAIL_PASSWORD
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=tuemail@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_DEFAULT_SENDER=tuemail@gmail.com
